                    </div>
                    <div class="flex flex-col gap-1">
                        <span class="font-display text-4xl text-white tracking-wide">7</span>
                        <span class="text-xs font-semibold uppercase tracking-[3px] text-sf-muted-dark">Book Parts</span>
                    </div>
                    <div class="flex flex-col gap-1">
                        <span class="font-display text-4xl text-white tracking-wide">4</span>
                        <span class="text-xs font-semibold uppercase tracking-[3px] text-sf-muted-dark">AI Skills</span>
                    </div>
                </div>

                <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-on-scroll stagger-3">
                    <a href="/ArchAssessment" class="inline-flex items-center justify-center px-8 py-4 bg-sf-red hover:bg-sf-red-dark text-white font-semibold text-sm tracking-wide uppercase transition-colors rounded-sm">
                        Start the Assessment &rarr;
                    </a>
                    <a href="#method" class="inline-flex items-center justify-center px-8 py-4 border border-sf-border hover:border-sf-red text-white font-semibold text-sm tracking-wide uppercase transition-colors rounded-sm">
