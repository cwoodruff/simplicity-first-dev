    <!-- ============================================================ -->
    <!-- 2. HERO SECTION                                              -->
    <!-- ============================================================ -->
    <section id="hero" class="hero-pattern relative min-h-screen flex items-center pt-20 overflow-hidden" aria-label="Hero">
